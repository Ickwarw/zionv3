  "configuracoesChartJS": {
    "default": {
      "responsive": true,
      "maintainAspectRatio": false,
      "animation": {
        "duration": 1000,
        "easing": "easeInOutQuart"
      },
      "plugins": {
        "legend": {
          "display": true,
          "position": "top",
          "labels": {
            "font": {
              "size": 14
            },
            "color": "#333"
          }
        },
        "tooltip": {
          "enabled": true,
          "mode": "index",
          "intersect": false
        }
      }
    },
    "bar": {
      "scales": {
        "y": {
          "beginAtZero": true,
          "title": {
            "display": true,
            "text": "Quantidade"
          }
        }
      }
    },
    "line": {
      "elements": {
        "line": {
          "tension": 0.4,
          "borderWidth": 3
        },
        "point": {
          "radius": 5,
          "hoverRadius": 7
        }
      }
    },
    "pie": {
      "plugins": {
        "legend": {
          "position": "right"
        }
      }
    },
    "doughnut": {
      "cutout": "70%",
      "plugins": {
        "legend": {
          "position": "right"
        }
      }
    },
    "radar": {
      "scales": {
        "r": {
          "beginAtZero": true,
          "max": 100
        }
      }
    }
  },
  
  "apiEndpoints": {
    "base": "http://localhost:5004",
    "endpoints": {
      "assuntos": "/api/dashboard/assuntos",
      "assuntoData": "/api/dashboard/assuntos/:key",
      "estatisticas": "/api/dashboard/estatisticas",
      "graficos": "/api/dashboard/graficos",
      "criarGrafico": "/api/dashboard/graficos",
      "grafico": "/api/dashboard/graficos/:id",
      "atualizarGrafico": "/api/dashboard/graficos/:id",
      "deletarGrafico": "/api/dashboard/graficos/:id",
      "dadosGrafico": "/api/dashboard/graficos/:id/dados",
      "predefinidos": "/api/dashboard/graficos-predefinidos",
      "health": "/health"
    }
  },
  
  "validacoes": {
    "titulo": {
      "required": true,
      "minLength": 3,
      "maxLength": 200
    },
    "tipo_grafico": {
      "required": true,
      "enum": ["bar", "line", "pie", "doughnut", "radar", "polarArea"]
    },
    "assuntos": {
      "required": true,
      "minItems": 1,
      "maxItems": 10
    }
  },
  
  "limites": {
    "maxAssuntosPorGrafico": 10,
    "maxGraficosSalvos": 100,
    "maxResultadosQuery": 1000,
    "cacheTimeout": 300
  },
  
