  "endpoints_api": {
    "base_url": "http://localhost:5004",
    "documentacao": "http://localhost:5004/api/docs",
    "rotas": {
      "dashboard": {
        "listar_assuntos": {
          "method": "GET",
          "path": "/api/dashboard/assuntos",
          "params": {
            "categoria": "string (opcional)"
          },
          "retorno": "Lista de assuntos com label, descricao e categoria"
        },
        "listar_categorias": {
          "method": "GET",
          "path": "/api/dashboard/categorias",
          "retorno": "Lista de todas as categorias disponíveis"
        },
        "obter_dados_assunto": {
          "method": "GET",
          "path": "/api/dashboard/assuntos/{assunto_key}",
          "retorno": "Dados prontos para Chart.js (labels e data)"
        },
        "estatisticas_gerais": {
          "method": "GET",
          "path": "/api/dashboard/estatisticas",
          "retorno": "Estatísticas para 12 cards principais"
        },
        "listar_graficos": {
          "method": "GET",
          "path": "/api/dashboard/graficos",
          "params": {
            "ativo": "boolean (opcional)"
          },
          "retorno": "Lista de gráficos salvos pelo usuário"
        },
        "obter_grafico": {
          "method": "GET",
          "path": "/api/dashboard/graficos/{id}",
          "retorno": "Detalhes de um gráfico específico"
        },
        "obter_dados_grafico": {
          "method": "GET",
          "path": "/api/dashboard/graficos/{id}/dados",
          "retorno": "Dados do gráfico prontos para Chart.js"
        },
        "criar_grafico": {
          "method": "POST",
          "path": "/api/dashboard/graficos",
          "body": {
            "titulo": "string (required, 3-200 chars)",
            "descricao": "string (optional)",
            "tipo_grafico": "string (bar|line|pie|doughnut|radar|polarArea)",
            "assuntos": "array (1-10 items)",
            "configuracoes": "object (optional)"
          },
          "retorno": "Gráfico criado com ID"
        },
        "atualizar_grafico": {
          "method": "PUT",
          "path": "/api/dashboard/graficos/{id}",
          "retorno": "Gráfico atualizado"
        },
        "deletar_grafico": {
          "method": "DELETE",
          "path": "/api/dashboard/graficos/{id}",
          "retorno": "Confirmação de exclusão (soft delete)"
        },
        "graficos_predefinidos": {
          "method": "GET",
          "path": "/api/dashboard/graficos-predefinidos",
          "retorno": "12 gráficos prontos para uso imediato"
        }
      },
      "crud": {
        "lead": {
          "base": "/api/lead",
          "metodos": ["GET", "POST", "PUT", "DELETE"],
          "descricao": "CRUD completo da tabela lead"
        },
        "contratos": {
          "base": "/api/contratos",
          "metodos": ["GET", "POST", "PUT", "DELETE"],
          "descricao": "Gerenciamento de contratos"
        },
        "servicos": {
          "base": "/api/servicos",
          "metodos": ["GET", "POST", "PUT", "DELETE"],
          "descricao": "Gerenciamento de serviços contratados"
        },
        "chamados": {
          "base": "/api/chamados",
          "metodos": ["GET", "POST", "PUT", "DELETE"],
          "descricao": "Sistema completo de chamados/OSS"
        },
        "usuarios": {
          "base": "/api/usuarios",
          "metodos": ["GET", "POST", "PUT", "DELETE"],
          "descricao": "Gerenciamento de usuários do sistema"
        }
      }
    }
  },

