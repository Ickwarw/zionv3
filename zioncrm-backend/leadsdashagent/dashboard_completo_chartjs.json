      "html": "<canvas id=\"meuGrafico\" width=\"400\" height=\"200\"></canvas>",
      "javascript": "const ctx = document.getElementById('meuGrafico').getContext('2d');\n\n// Buscar dados da API\nfetch('http://localhost:5004/api/dashboard/assuntos/contratos_ativos_por_mes')\n  .then(response => response.json())\n  .then(result => {\n    const chartData = result.data;\n    \n    new Chart(ctx, {\n      type: 'line',\n      data: {\n        labels: chartData.labels,\n        datasets: [{\n          label: chartData.label,\n          data: chartData.data,\n          borderColor: '#3b82f6',\n          backgroundColor: 'rgba(59, 130, 246, 0.1)',\n          tension: 0.4\n        }]\n      },\n      options: {\n        responsive: true,\n        plugins: {\n          legend: {\n            display: true,\n            position: 'top'\n          },\n          tooltip: {\n            mode: 'index',\n            intersect: false\n          }\n        },\n        scales: {\n          y: {\n            beginAtZero: true\n          }\n        }\n      }\n    });\n  });"
    }
