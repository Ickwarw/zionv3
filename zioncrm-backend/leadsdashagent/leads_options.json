      "delete": "/api/leads/:id",
      "classify": "/api/leads/:id/classify",
      "byDepartment": "/api/leads/by-department/:dept",
      "byPriority": "/api/leads/by-priority/:priority",
      "stats": "/api/leads/stats/advanced"
    }
  },
  
  "paginacao": {
    "defaultPage": 1,
    "defaultPerPage": 50,
